# =============================================================================
# Payroll Copilot — Production / AWS Environment
# =============================================================================
# Inject via orchestrator (ECS/Secrets Manager/Parameter Store). Do not commit secrets.
#
# Defaults: Amazon S3, DynamoDB, Cognito, SES, Bedrock, CloudWatch.
# Ollama is local-development only — do not set MODEL_PROVIDER=ollama here.
#
# Companion templates:
#   .env.example              — same AWS defaults (repo reference)
#   .env.docker.example       — local Docker substitutes (MinIO, DynamoDB Local, Ollama)
#   .env.local.example        — host-local substitutes
# =============================================================================

# Application
APP_NAME=Payroll Copilot
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-a-random-64-char-string
DEFAULT_LOCALE=he
API_PREFIX=/api/v1
AWS_REGION=us-east-1

# Legacy PostgreSQL — NOT used at runtime (DynamoDB is primary). Leave unset.
# DATABASE_URL=
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# Amazon DynamoDB (primary business database)
DYNAMODB_TABLE_NAME=PayrollCopilot
DYNAMODB_REGION=us-east-1
DYNAMODB_ENDPOINT=
DYNAMODB_LOCAL_ENDPOINT=http://localhost:8001
DYNAMODB_AUTO_CREATE_TABLE=false

# Amazon SES (outbound email) — verify identity/domain in SES
SES_REGION=us-east-1
SES_FROM_EMAIL=noreply@example.com
SES_FROM_NAME=Payroll Copilot
SES_CONFIGURATION_SET=
SES_ENDPOINT=

# Redis (ElastiCache or equivalent in production)
REDIS_URL=redis://localhost:6379/0
REDIS_LOCAL_URL=redis://localhost:6379/0

# Amazon S3 (empty endpoint = real S3 + IAM / default credential chain)
S3_ENDPOINT=
S3_LOCAL_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=payroll-copilot
S3_REGION=us-east-1
S3_USE_SSL=true
S3_AUTO_CREATE_BUCKET=false

SERVICE_AUTO_FALLBACK=false
SERVICE_PROBE_TIMEOUT_SECONDS=0.5

# JWT — guest landing tokens only (authenticated users use Cognito)
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Amazon Cognito (required in production)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=
COGNITO_APP_CLIENT_SECRET=

# Encryption (PII — national ID)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Guest Sessions
GUEST_SESSION_TTL_HOURS=24

GUEST_VALIDATION_CONFIDENCE_PENALTY_ATTENDANCE=0.12
GUEST_VALIDATION_CONFIDENCE_PENALTY_CONTRACT=0.12
GUEST_VALIDATION_CONFIDENCE_PENALTY_NATIONAL_ID=0.08
GUEST_VALIDATION_CONFIDENCE_PENALTY_HISTORICAL=0.08
GUEST_VALIDATION_CONFIDENCE_PENALTY_EXTRACTION=0.20
GUEST_VALIDATION_CONFIDENCE_MINIMUM=0.35

# Amazon Bedrock (production LLM — do not use Ollama in production)
MODEL_PROVIDER=bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSIONS=1024
BEDROCK_ENDPOINT=

# Ollama keys retained for schema compatibility — unused when MODEL_PROVIDER=bedrock
OLLAMA_BASE_URL=
OLLAMA_LOCAL_URL=http://127.0.0.1:11434
OLLAMA_HOST_URL=http://host.docker.internal:11434
OLLAMA_DOCKER_URL=http://ollama:11434
OLLAMA_AUTO_FALLBACK=false
OLLAMA_PROBE_TIMEOUT_SECONDS=2.0
OLLAMA_DEFAULT_MODEL=mistral-nemo:12b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
PAYSLIP_PARSER_MODEL=
PAYSLIP_PARSER_TIMEOUT_SECONDS=180
PAYSLIP_PARSER_USE_JSON_FORMAT=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OCR
OCR_PROVIDER=paddleocr
TESSERACT_LANG=heb+eng
OCR_TIMEOUT_SECONDS=120
OCR_USE_GPU=false
OCR_PREPROCESSING_ENABLED=true
OCR_PREPROCESSING_TARGET_LONG_EDGE=2000
OCR_PREPROCESSING_MAX_SCALE_FACTOR=3.0
OCR_PREPROCESSING_MAX_PIXELS=20000000
OCR_PREPROCESSING_CONTRAST_FACTOR=1.4
OCR_PREPROCESSING_SHARPNESS_FACTOR=1.3
OCR_TESSERACT_MULTI_PSM_ENABLED=true
OCR_TESSERACT_PSM_CANDIDATES=3,4,6,11
OCR_TESSERACT_DEFAULT_OEM=3
OCR_TESSERACT_MAX_CANDIDATES=4
OCR_TESSERACT_MIN_VALID_WORD_CONFIDENCE=0.0
PAYSLIP_PARSER_LAYOUT_ENABLED=true
PAYSLIP_PARSER_INCLUDE_WORDS=true
PAYSLIP_PARSER_MAX_LINES=300
PAYSLIP_PARSER_MAX_WORDS=2000
PAYSLIP_PARSER_MIN_WORD_CONFIDENCE=0.0
PAYSLIP_PARSER_MAX_CONTEXT_CHARS=50000

# Phase 1 layout preservation (additive snapshot only; default off = existing behavior)
LAYOUT_SNAPSHOT_ENABLED=false
LAYOUT_SNAPSHOT_INCLUDE_WORDS=true
LAYOUT_SNAPSHOT_MAX_PAGES=20
LAYOUT_SNAPSHOT_MAX_WORDS=8000
LAYOUT_SNAPSHOT_MAX_LINES=2000

# Phase 2 structure builder + association engine (additive analysis only; default off)
LAYOUT_STRUCTURE_ENABLED=false
LAYOUT_STRUCTURE_MIN_TABLE_ROWS=3
LAYOUT_STRUCTURE_MAX_ALTERNATIVES=3

# Phase 3 evidence-bound LLM mapping (default off; reuses Phase 2 analysis)
PAYSLIP_PARSER_EVIDENCE_BOUND_ENABLED=false
LAYOUT_EXPLAINABILITY_ENABLED=false

# Celery (Redis / ElastiCache)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_BROKER_LOCAL_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_RESULT_BACKEND_LOCAL_URL=redis://localhost:6379/2

MAX_UPLOAD_SIZE_MB=50
MAX_BULK_PDF_SIZE_MB=200

RATE_LIMIT_GUEST_UPLOADS_PER_HOUR=5
RATE_LIMIT_EMPLOYEE_UPLOADS_PER_HOUR=20

RULES_CONFIG_PATH=config/rules
LEGAL_RULES_PATH=config/rules/labor_law
DEPARTMENT_RULES_PATH=config/rules/departments

RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.7

MCP_ENABLED=true
KOL_ZCHUT_BASE_URL=https://www.kolzchut.org.il

N8N_API_KEY=

# Logging → stdout JSON; platform ships to CloudWatch Logs
LOG_LEVEL=INFO
LOG_FORMAT=json
CLOUDWATCH_ENABLED=true
CLOUDWATCH_LOG_GROUP=/payroll-copilot/api
CLOUDWATCH_METRICS_NAMESPACE=PayrollCopilot

# Production SPA origins only
CORS_ORIGINS=https://app.example.com
