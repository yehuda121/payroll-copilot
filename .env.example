# =============================================================================
# Payroll Copilot — Docker Development Environment (PRIMARY)
# =============================================================================
# Used by: docker compose up --build
# Compose services load this file via env_file: .env
#
# Setup:
#   copy .env.docker.example .env
#   (or copy .env.example .env — same Docker defaults)
#
# Hosts inside containers: postgres / redis / minio (Compose network DNS)
# Do NOT use localhost for DATABASE_URL / REDIS_URL / S3_ENDPOINT here.
#
# For host-local backend (uvicorn on Windows/macOS/Linux):
#   use .env.local.example → .env.local instead.
#
# Future production: inject the same keys via the orchestrator; do not commit secrets.
# =============================================================================

# Application
APP_NAME=Payroll Copilot
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
DEFAULT_LOCALE=he
API_PREFIX=/api/v1

# Database (Compose hostname — shared by FastAPI + Alembic migrate service)
DATABASE_URL=postgresql+asyncpg://payroll:payroll@postgres:5432/payroll_copilot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (Compose hostname; *_LOCAL_URL is unused inside Docker)
REDIS_URL=redis://redis:6379/0
REDIS_LOCAL_URL=redis://localhost:6379/0

# Object Storage (MinIO / S3)
S3_ENDPOINT=http://minio:9000
S3_LOCAL_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=payroll-copilot
S3_REGION=us-east-1
S3_USE_SSL=false

# Local-vs-Docker service resolution (Redis/Celery/S3). Safe to leave enabled in Docker;
# Docker hostnames resolve, so fallbacks are not used.
SERVICE_AUTO_FALLBACK=true
SERVICE_PROBE_TIMEOUT_SECONDS=0.5

# JWT Authentication
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (PII — national ID)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Guest Sessions
GUEST_SESSION_TTL_HOURS=24

# Guest validation report confidence (evidence-based penalties, not LLM)
GUEST_VALIDATION_CONFIDENCE_PENALTY_ATTENDANCE=0.12
GUEST_VALIDATION_CONFIDENCE_PENALTY_CONTRACT=0.12
GUEST_VALIDATION_CONFIDENCE_PENALTY_NATIONAL_ID=0.08
GUEST_VALIDATION_CONFIDENCE_PENALTY_HISTORICAL=0.08
GUEST_VALIDATION_CONFIDENCE_PENALTY_EXTRACTION=0.20
GUEST_VALIDATION_CONFIDENCE_MINIMUM=0.35

# AI / LLM
MODEL_PROVIDER=ollama

# Ollama URL resolution (see README — Ollama section)
OLLAMA_BASE_URL=
OLLAMA_LOCAL_URL=http://127.0.0.1:11434
OLLAMA_HOST_URL=http://host.docker.internal:11434
OLLAMA_DOCKER_URL=http://ollama:11434
OLLAMA_AUTO_FALLBACK=true
OLLAMA_PROBE_TIMEOUT_SECONDS=2.0
OLLAMA_DEFAULT_MODEL=mistral-nemo:12b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
PAYSLIP_PARSER_MODEL=
PAYSLIP_PARSER_TIMEOUT_SECONDS=180
PAYSLIP_PARSER_USE_JSON_FORMAT=true

# OpenAI (optional — set MODEL_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OCR
OCR_PROVIDER=paddleocr
TESSERACT_LANG=heb+eng+ara
OCR_TIMEOUT_SECONDS=120
OCR_USE_GPU=false

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_BROKER_LOCAL_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_RESULT_BACKEND_LOCAL_URL=redis://localhost:6379/2

# File Upload Limits
MAX_UPLOAD_SIZE_MB=50
MAX_BULK_PDF_SIZE_MB=200

# Rate Limiting
RATE_LIMIT_GUEST_UPLOADS_PER_HOUR=5
RATE_LIMIT_EMPLOYEE_UPLOADS_PER_HOUR=20

# Rules
RULES_CONFIG_PATH=config/rules
LEGAL_RULES_PATH=config/rules/labor_law
DEPARTMENT_RULES_PATH=config/rules/departments

# RAG
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.7

# MCP Legal Sync
MCP_ENABLED=true
KOL_ZCHUT_BASE_URL=https://www.kolzchut.org.il

# n8n Integration
N8N_API_KEY=change-me-integration-key

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS — browser origins (Vite on :3000 is the Docker frontend)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
