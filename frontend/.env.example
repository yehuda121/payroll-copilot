# Frontend environment — copy to frontend/.env.local for host-only Vite.
# When using docker compose, the frontend service sets these via Compose environment
# (VITE_API_BASE_URL / VITE_DEV_AUTH_ENABLED) — no file required.

VITE_API_BASE_URL=http://localhost:8000/api/v1

# Local development: true = role-picker (no Cognito UI).
# Production / Cognito: false — email/password → POST /auth/login
#   (requires COGNITO_USER_POOL_ID + COGNITO_APP_CLIENT_ID on the API).
VITE_DEV_AUTH_ENABLED=true
